      "x": 110,
      "y": 330,
      "width": 1020,
      "height": 140,
      "text": "Manual Trigger/Cron → Google Drive (Source Docs) → Extract from File → RecursiveCharacterTextSplitter (chunk ~500-1000 tokens) → OpenAI Embeddings (text-embedding-3-small) → Pinecone Upsert (3 Namespaces: marketing, projects, faq)",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#475569",
      "textAlign": "center",
      "originalText": "Manual Trigger/Cron → Google Drive (Source Docs) → Extract from File → RecursiveCharacterTextSplitter (chunk ~500-1000 tokens) → OpenAI Embeddings (text-embedding-3-small) → Pinecone Upsert (3 Namespaces: marketing, projects, faq)",
      "autoResize": true
    },
