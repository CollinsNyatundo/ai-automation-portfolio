    {
      "type": "text",
      "id": "tools_list",
      "x": 290,
      "y": 240,
      "width": 680,
      "height": 160,
      "text": "1. Think Tool          → Self-verification before acting\n2. Pinecone RAG        → Internal knowledge base (FAQ namespace)\n3. Gmail Tool          → Send emails, find contacts\n4. Airtable Tool       → Contact management (CRM)\n5. Tavily Web Search   → Real-time web research\n6. Calendar Tool       → Schedule events, check availability\n7. Email Tool          → Compose + send (signs off as \"Nate\")",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e",
      "textAlign": "left",
      "originalText": "1. Think Tool          → Self-verification before acting\n2. Pinecone RAG        → Internal knowledge base (FAQ namespace)\n3. Gmail Tool          → Send emails, find contacts\n4. Airtable Tool       → Contact management (CRM)\n5. Tavily Web Search   → Real-time web research\n6. Calendar Tool       → Schedule events, check availability\n7. Email Tool          → Compose + send (signs off as \"Nate\")",
      "autoResize": true
    },
